<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="ProjetUniv_scheduler.MainController"
            prefHeight="700.0" prefWidth="1100.0"
            style="-fx-background-color: #FFFFFF;">

    <left>
        <VBox fx:id="sidebar" spacing="12" style="-fx-background-color: #1E2732; -fx-min-width: 240; -fx-padding: 25;">

            <Label text="UNIV-SCHEDULER"
                   style="-fx-text-fill: #A3FF33; -fx-font-size: 20; -fx-font-weight: bold; -fx-padding: 0 0 20 0;"/>

            <Separator style="-fx-opacity: 0.4; -fx-background-color: #A3FF33;"/>

            <Button fx:id="btnDashboard"
                    text="🏠  Tableau de bord"
                    onAction="#showDashboard"
                    style="-fx-background-color: transparent; -fx-text-fill: #A3FF33; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-font-size: 14; -fx-font-weight: bold;"
                    maxWidth="Infinity" prefHeight="45"/>

            <Button fx:id="btnSalles"
                    text="🏫  Gestion des Salles"
                    onAction="#showSalles"
                    style="-fx-background-color: transparent; -fx-text-fill: #A3FF33; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-font-size: 14; -fx-font-weight: bold;"
                    maxWidth="Infinity" prefHeight="45"/>

            <Button fx:id="btnPlanification"
                    text="📅  Planification"
                    onAction="#showManagerDashboard"
                    style="-fx-background-color: transparent; -fx-text-fill: #A3FF33; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-font-size: 14; -fx-font-weight: bold;"
                    maxWidth="Infinity" prefHeight="45"/>

            <Button fx:id="btnReservations"
                    text="⚡  Réservations"
                    onAction="#showReservations"
                    style="-fx-background-color: transparent; -fx-text-fill: #A3FF33; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-font-size: 14; -fx-font-weight: bold;"
                    maxWidth="Infinity" prefHeight="45"/>

            <Button fx:id="btnAdministration"
                    text="🛠️  Administration"
                    onAction="#showAdminPanel"
                    style="-fx-background-color: transparent; -fx-text-fill: #A3FF33; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-font-size: 14; -fx-font-weight: bold;"
                    maxWidth="Infinity" prefHeight="45"/>

            <Button fx:id="btnNotifications"
                    text="🔔  Notifications"
                    onAction="#showNotifications"
                    style="-fx-background-color: transparent; -fx-text-fill: #A3FF33; -fx-alignment: CENTER_LEFT; -fx-cursor: hand; -fx-font-size: 14; -fx-font-weight: bold;"
                    maxWidth="Infinity" prefHeight="45"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button fx:id="btnLogout"
                    text="⏻  DÉCONNEXION"
                    onAction="#handleLogout"
                    style="-fx-background-color: transparent; -fx-text-fill: #A3FF33; -fx-border-color: #A3FF33; -fx-border-radius: 5; -fx-alignment: CENTER; -fx-cursor: hand; -fx-font-size: 12; -fx-font-weight: bold;"
                    maxWidth="Infinity" prefHeight="40">
                <VBox.margin>
                    <Insets bottom="10"/>
                </VBox.margin>
            </Button>

            <Label text="© 2026 UIDT Cyber-System"
                   style="-fx-text-fill: #A3FF33; -fx-font-size: 10; -fx-opacity: 0.6;"/>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: transparent; -fx-background: #FFFFFF; -fx-border-color: transparent;">
            <VBox fx:id="mainContent" spacing="25"
                  style="-fx-background-color: #FFFFFF;">
                <padding>
                    <Insets top="40" right="40" bottom="40" left="40"/>
                </padding>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>