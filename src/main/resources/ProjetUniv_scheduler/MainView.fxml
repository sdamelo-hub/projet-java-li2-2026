<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.lang.String?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="ProjetUniv_scheduler.MainController"
            prefHeight="700.0" prefWidth="1100.0"
            style="-fx-background-color: #F0F4FF;">

    <stylesheets>
        <String fx:value="/ProjetUniv_scheduler/STYLE/modern.css" />
    </stylesheets>

    <left>
        <VBox prefWidth="260" styleClass="sidebar">
            <children>
                <VBox styleClass="sidebar-header" alignment="CENTER" prefHeight="120">
                    <Label text="UNIV-SCHEDULER" styleClass="sidebar-logo" />
                    <Label text="Gestion Intelligente"
                           style="-fx-text-fill: white; -fx-opacity: 0.85; -fx-font-size: 11;"/>
                </VBox>

                <VBox spacing="8">
                    <padding>
                        <Insets top="20" right="20" bottom="10" left="20"/>
                    </padding>

                    <Button text="🏠  Tableau de bord" onAction="#showDashboard"
                            styleClass="menu-item" maxWidth="Infinity" />

                    <Button text="🏫  Gestion des Salles" onAction="#showSalles"
                            styleClass="menu-item" maxWidth="Infinity" />

                    <Button text="🔐  Se Connecter" onAction="#showLogin"
                            styleClass="btn-connexion" maxWidth="Infinity" />

                    <Button text="📅  Réservations" onAction="#showReservations"
                            styleClass="menu-item" maxWidth="Infinity" />

                    <Button text="🔔  Notifications" onAction="#showNotifications"
                            styleClass="menu-item" maxWidth="Infinity" />
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <Label text="© 2026 UIDT Cyber-System"
                       style="-fx-text-fill: #90CAF9; -fx-font-size: 10; -fx-opacity: 0.6; -fx-padding: 20;"/>
            </children>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: transparent; -fx-background: #F0F4FF; -fx-border-color: transparent;">
            <content>
                <VBox fx:id="mainContent" spacing="30" style="-fx-background-color: #F0F4FF;">
                    <padding>
                        <Insets top="40" right="40" bottom="40" left="40"/>
                    </padding>
                    <Label text="Bienvenue sur le système de gestion de l'UIDT"
                           style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #0D1B2A;"/>
                    <FlowPane fx:id="containerSalles" hgap="25" vgap="25"/>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>