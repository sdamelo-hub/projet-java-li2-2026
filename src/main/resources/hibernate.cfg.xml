<?xml version="1.0" encoding="UTF-8"?>
        <!DOCTYPE hibernate-configuration PUBLIC
                "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
                "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>
        <!--  ═══ Connexion MySQL ═══════════════════════════════════════════  -->
        <property name="connection.driver_class">com.mysql.cj.jdbc.Driver</property>
        <property name="connection.url"> jdbc:mysql://localhost:3306/univ_scheduler?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true </property>
        <property name="connection.username">root</property>
        <property name="connection.password"/>
        <!--  ═══ Dialecte &amp; Affichage ══════════════════════════════════  -->
        <property name="dialect">org.hibernate.dialect.MySQL8Dialect</property>
        <property name="show_sql">true</property>
        <property name="format_sql">true</property>
        <!--  ═══ Schéma ════════════════════════════════════════════════════  -->
        <!--  "update" crée et met à jour les tables sans supprimer les données  -->
        <property name="hbm2ddl.auto">update</property>
        <!--  ═══ Pool de connexions ════════════════════════════════════════  -->
        <property name="connection.pool_size">10</property>
        <property name="current_session_context_class">thread</property>
        <!--  ═══ Support Java 8 Time (LocalDate, LocalTime, etc.) ══════════  -->
        <!--  CRITIQUE : Doit être présent pour que LocalDate/LocalTime fonctionnent  -->
        <property name="hibernate.integrator_provider"> org.hibernate.type.descriptor.java.LocalDateJavaTypeDescriptor </property>
        <!--  ═══ Mappings — Utilisateurs ══════════════════════════════════  -->
        <mapping class="ProjetUniv_scheduler.Mesclasses.Utilisateur"/>
        <mapping class="ProjetUniv_scheduler.Mesclasses.Administrateur"/>
        <mapping class="ProjetUniv_scheduler.Mesclasses.Gestionnaire"/>
        <mapping class="ProjetUniv_scheduler.Mesclasses.Enseignant"/>
        <mapping class="ProjetUniv_scheduler.Mesclasses.Etudiant"/>
        <!--  ═══ Mappings — Structure Universitaire ════════════════════════  -->
        <mapping class="ProjetUniv_scheduler.Mesclasses.UFR"/>
        <mapping class="ProjetUniv_scheduler.Mesclasses.Departement"/>
        <mapping class="ProjetUniv_scheduler.Mesclasses.Filiere"/>
        <mapping class="ProjetUniv_scheduler.Mesclasses.Promotion"/>
        <mapping class="ProjetUniv_scheduler.Mesclasses.Groupe"/>
        <!--  ═══ Mappings — Infrastructure ════════════════════════════════  -->
        <mapping class="ProjetUniv_scheduler.Mesclasses.Batiment"/>
        <mapping class="ProjetUniv_scheduler.Mesclasses.Salle"/>
        <mapping class="ProjetUniv_scheduler.Mesclasses.Equipement"/>
        <!--  ═══ Mappings — Pédagogie ══════════════════════════════════════  -->
        <mapping class="ProjetUniv_scheduler.Mesclasses.Cours"/>
        <mapping class="ProjetUniv_scheduler.Mesclasses.Creneau"/>
        <!--  ═══ Mappings — Fonctionnel ════════════════════════════════════  -->
        <mapping class="ProjetUniv_scheduler.Mesclasses.Reservation"/>
        <mapping class="ProjetUniv_scheduler.Mesclasses.Incident"/>
        <mapping class="ProjetUniv_scheduler.Mesclasses.Notification"/>
        <mapping class="ProjetUniv_scheduler.Mesclasses.Statistique"/>
    </session-factory>
</hibernate-configuration>